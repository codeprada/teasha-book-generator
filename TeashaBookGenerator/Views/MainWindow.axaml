<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TeashaBookGenerator.ViewModels"
        xmlns:models="using:TeashaBookGenerator.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="TeashaBookGenerator.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Teasha Book Generator - Text Overlay Tool"
        MinWidth="900" MinHeight="600"
        Width="1200" Height="800">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Top Toolbar -->
        <Border Grid.Row="0" Background="#f0f0f0" Padding="10" BorderBrush="#ccc" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Content="Load Image" Click="OnLoadImageClick" VerticalAlignment="Center"/>
                <Button Content="Open Project"
                        Command="{Binding OpenProjectCommand}"
                        VerticalAlignment="Center"/>
                <Button Content="Save Project"
                        Command="{Binding SaveProjectCommand}"
                        VerticalAlignment="Center"
                        IsEnabled="{Binding IsImageLoaded}"/>
                <Border Width="1" Background="#ccc" Margin="4,2"/>
                <Button Content="+ Text Region"
                        Command="{Binding AddTextOverlayCommand}"
                        VerticalAlignment="Center"
                        IsEnabled="{Binding IsImageLoaded}"/>
                <Button Content="+ Image Region"
                        Command="{Binding AddImageOverlayCommand}"
                        VerticalAlignment="Center"
                        IsEnabled="{Binding IsImageLoaded}"/>
                <Button Content="Remove Selected"
                        Command="{Binding RemoveOverlayCommand}"
                        VerticalAlignment="Center"
                        IsEnabled="{Binding SelectedOverlay, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Margin="10,0,0,0"
                           Foreground="#555" FontSize="13"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" ColumnDefinitions="*,340">

            <!-- Image Canvas Area -->
            <Border Grid.Column="0" Margin="10" BorderBrush="#aaa" BorderThickness="1"
                    Background="#e8e8e8" ClipToBounds="True">
                <Panel>
                    <TextBlock Text="Load an image, then add text or image regions"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="#999" FontSize="14"
                               IsVisible="{Binding !IsImageLoaded}"/>

                    <Canvas Name="ImageCanvas"
                            PointerPressed="OnCanvasPointerPressed"
                            PointerMoved="OnCanvasPointerMoved"
                            PointerReleased="OnCanvasPointerReleased"
                            Background="Transparent"
                            IsVisible="{Binding IsImageLoaded}">
                        <Image Name="DisplayImage"
                               Source="{Binding ImageSource}"
                               Stretch="Uniform"/>
                        <!-- Drawing-mode selection rectangle -->
                        <Border Name="SelectionBox"
                                BorderBrush="#2196F3"
                                BorderThickness="2"
                                Background="#332196F3"
                                IsVisible="False"/>
                    </Canvas>
                </Panel>
            </Border>

            <!-- Controls Panel -->
            <Border Grid.Column="1" Background="#fafafa" Padding="15" BorderBrush="#ccc" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12">

                        <!-- Overlay List -->
                        <TextBlock Text="Overlay Regions" FontWeight="Bold" FontSize="16" Margin="0,0,0,2"/>
                        <ListBox ItemsSource="{Binding Overlays}"
                                 SelectedItem="{Binding SelectedOverlay}"
                                 MaxHeight="160">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="models:OverlayRegion">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Border Background="#e0e0e0" CornerRadius="3" Padding="4,1"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding TypeIcon}" FontSize="10"
                                                       FontWeight="Bold" Foreground="#555"/>
                                        </Border>
                                        <TextBlock Text="{Binding Label}" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Summary}" Foreground="#888"
                                                   MaxWidth="160" TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Region position/size (shared) -->
                        <Border Background="#fff" Padding="10" CornerRadius="4"
                                BorderBrush="#ddd" BorderThickness="1"
                                IsVisible="{Binding SelectedOverlay, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <TextBlock FontSize="12" Foreground="#666">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="Position: ({0:F0}, {1:F0})  Size: {2:F0} x {3:F0}">
                                        <Binding Path="SelectedOverlay.X"/>
                                        <Binding Path="SelectedOverlay.Y"/>
                                        <Binding Path="SelectedOverlay.Width"/>
                                        <Binding Path="SelectedOverlay.Height"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Border>

                        <!-- TEXT OVERLAY PROPERTIES -->
                        <Border Background="#fff" Padding="12" CornerRadius="4"
                                BorderBrush="#ddd" BorderThickness="1"
                                IsVisible="{Binding IsTextOverlaySelected}">
                            <StackPanel Spacing="10" DataContext="{Binding SelectedTextOverlay}"
                                        x:DataType="models:TextOverlayRegion">

                                <TextBlock Text="Text Properties" FontWeight="Bold" FontSize="14"/>

                                <TextBlock Text="Overlay Text" FontWeight="SemiBold" FontSize="13"/>
                                <TextBox Text="{Binding Text}"
                                         Watermark="Enter text to overlay..."
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="80"
                                         MaxHeight="160"/>

                                <TextBlock Text="Font Family" FontWeight="SemiBold" FontSize="13"/>
                                <ComboBox ItemsSource="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).AvailableFonts}"
                                          SelectedItem="{Binding SelectedFont}"
                                          HorizontalAlignment="Stretch">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="models:EmbeddedFont">
                                            <TextBlock Text="{Binding DisplayName}" FontFamily="{Binding FontFamily}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBlock Text="Font Size" FontWeight="SemiBold" FontSize="13"/>
                                <ComboBox ItemsSource="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).FontSizes}"
                                          SelectedItem="{Binding FontSize}"
                                          HorizontalAlignment="Stretch"/>

                                <TextBlock Text="Font Color" FontWeight="SemiBold" FontSize="13"/>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBox Grid.Column="0" Text="{Binding FontColor}"
                                             Watermark="#000000" Margin="0,0,8,0"/>
                                    <Border Grid.Column="1" Width="32" Height="32" CornerRadius="4"
                                            BorderBrush="#ccc" BorderThickness="1">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding FontColor}"/>
                                        </Border.Background>
                                    </Border>
                                </Grid>

                                <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <Button Content="  " Background="Black" Margin="2" Click="OnColorClick" Tag="#000000"
                                            Width="28" Height="28" Padding="0"/>
                                    <Button Content="  " Background="White" Margin="2" Click="OnColorClick" Tag="#FFFFFF"
                                            Width="28" Height="28" Padding="0" BorderBrush="#ccc" BorderThickness="1"/>
                                    <Button Content="  " Background="Red" Margin="2" Click="OnColorClick" Tag="#FF0000"
                                            Width="28" Height="28" Padding="0"/>
                                    <Button Content="  " Background="Blue" Margin="2" Click="OnColorClick" Tag="#0000FF"
                                            Width="28" Height="28" Padding="0"/>
                                    <Button Content="  " Background="Green" Margin="2" Click="OnColorClick" Tag="#008000"
                                            Width="28" Height="28" Padding="0"/>
                                    <Button Content="  " Background="Yellow" Margin="2" Click="OnColorClick" Tag="#FFFF00"
                                            Width="28" Height="28" Padding="0"/>
                                    <Button Content="  " Background="Orange" Margin="2" Click="OnColorClick" Tag="#FFA500"
                                            Width="28" Height="28" Padding="0"/>
                                    <Button Content="  " Background="Purple" Margin="2" Click="OnColorClick" Tag="#800080"
                                            Width="28" Height="28" Padding="0"/>
                                </WrapPanel>

                                <TextBlock Text="Text Alignment" FontWeight="SemiBold" FontSize="13"/>
                                <ComboBox ItemsSource="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).AlignmentOptions}"
                                          SelectedItem="{Binding Alignment}"
                                          HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Border>

                        <!-- IMAGE OVERLAY PROPERTIES -->
                        <Border Background="#fff" Padding="12" CornerRadius="4"
                                BorderBrush="#ddd" BorderThickness="1"
                                IsVisible="{Binding IsImageOverlaySelected}">
                            <StackPanel Spacing="10" DataContext="{Binding SelectedImageOverlay}"
                                        x:DataType="models:ImageOverlayRegion">

                                <TextBlock Text="Image Properties" FontWeight="Bold" FontSize="14"/>

                                <TextBlock Text="Image File" FontWeight="SemiBold" FontSize="13"/>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBox Grid.Column="0" Text="{Binding ImagePath}"
                                             IsReadOnly="True" Watermark="No image selected"
                                             Margin="0,0,8,0"/>
                                    <Button Grid.Column="1" Content="Browse"
                                            Click="OnBrowseOverlayImageClick"/>
                                </Grid>

                                <TextBlock Text="Opacity" FontWeight="SemiBold" FontSize="13"/>
                                <Grid ColumnDefinitions="*,50">
                                    <Slider Grid.Column="0" Minimum="0" Maximum="100"
                                            Value="{Binding Opacity}" TickFrequency="1"
                                            IsSnapToTickEnabled="True"/>
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                               HorizontalAlignment="Right">
                                        <TextBlock.Text>
                                            <Binding Path="Opacity" StringFormat="{}{0}%"/>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Placeholder when nothing selected -->
                        <TextBlock Text="Select or add an overlay region to edit its properties."
                                   Foreground="#999" FontSize="13" TextWrapping="Wrap"
                                   IsHitTestVisible="False">
                            <TextBlock.IsVisible>
                                <Binding Path="SelectedOverlay" Converter="{x:Static ObjectConverters.IsNull}"/>
                            </TextBlock.IsVisible>
                        </TextBlock>

                        <!-- Output Path -->
                        <TextBlock Text="Output Path" FontWeight="SemiBold" FontSize="13" Margin="0,8,0,0"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Grid.Column="0" Text="{Binding OutputPath}"
                                     Watermark="Output file path..." Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="Browse"
                                    Command="{Binding BrowseOutputCommand}"/>
                        </Grid>

                        <!-- Generate Button -->
                        <Button Content="Generate Image"
                                Command="{Binding GenerateCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Background="#2196F3"
                                Foreground="White"
                                FontWeight="Bold"
                                FontSize="15"
                                Padding="12"
                                Margin="0,10,0,0"/>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#f0f0f0" Padding="8" BorderBrush="#ccc" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#555"/>
        </Border>

    </Grid>
</Window>
