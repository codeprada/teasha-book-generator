<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TeashaBookGenerator.ViewModels"
        xmlns:models="using:TeashaBookGenerator.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
        x:Class="TeashaBookGenerator.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Teasha Book Generator"
        MinWidth="1000" MinHeight="640"
        Width="1280" Height="800"
        Background="{StaticResource SolidBackgroundBrush}">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- ═══════════════════ UPDATE BANNER ═══════════════════ -->
        <Border Grid.Row="0"
                Background="#005FB8"
                Padding="12,8"
                IsVisible="{Binding IsUpdateAvailable}">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <!-- Status text / progress -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center">
                    <TextBlock Text="Update available:" FontSize="13" FontWeight="SemiBold"
                               Foreground="White" VerticalAlignment="Center"
                               IsVisible="{Binding !IsUpdateDownloading}"/>
                    <TextBlock Text="{Binding UpdateVersion}" FontSize="13"
                               Foreground="White" VerticalAlignment="Center"
                               IsVisible="{Binding !IsUpdateDownloading}"/>
                    <TextBlock Text="Downloading update..." FontSize="13" FontWeight="SemiBold"
                               Foreground="White" VerticalAlignment="Center"
                               IsVisible="{Binding IsUpdateDownloading}"/>
                    <ProgressBar Minimum="0" Maximum="100"
                                 Value="{Binding UpdateDownloadProgress}"
                                 Width="160" Height="6"
                                 VerticalAlignment="Center"
                                 IsVisible="{Binding IsUpdateDownloading}"/>
                    <TextBlock FontSize="12" Foreground="White" VerticalAlignment="Center"
                               IsVisible="{Binding IsUpdateDownloading}">
                        <TextBlock.Text>
                            <Binding Path="UpdateDownloadProgress" StringFormat="{}{0}%"/>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>

                <!-- Download & Restart button -->
                <Button Grid.Column="1"
                        Command="{Binding DownloadAndApplyUpdateCommand}"
                        IsVisible="{Binding !IsUpdateDownloading}"
                        Margin="8,0"
                        Padding="12,4"
                        Background="White" Foreground="#005FB8"
                        FontSize="12" FontWeight="SemiBold"
                        CornerRadius="4">
                    <TextBlock Text="Download &amp; Restart"/>
                </Button>

                <!-- Dismiss button -->
                <Button Grid.Column="2"
                        Command="{Binding DismissUpdateCommand}"
                        IsVisible="{Binding !IsUpdateDownloading}"
                        Padding="6,2"
                        Background="Transparent"
                        CornerRadius="4">
                    <TextBlock Text="&#x2715;" Foreground="White" FontSize="14"/>
                </Button>
            </Grid>
        </Border>

        <!-- ═══════════════════ TOP COMMAND BAR ═══════════════════ -->
        <Border Grid.Row="1"
                Background="{StaticResource LayerFillBrush}"
                BorderBrush="{StaticResource SubtleStrokeBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,6">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Left: File actions -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
                    <Button Content="Load Image" Click="OnLoadImageClick" Classes="tb"/>
                    <Border Width="1" Background="{StaticResource SubtleStrokeBrush}" Margin="6,4"/>
                    <Button Content="Open Project" Command="{Binding OpenProjectCommand}" Classes="tb"/>
                    <Button Content="Save Project" Command="{Binding SaveProjectCommand}"
                            IsEnabled="{Binding IsImageLoaded}" Classes="tb"/>
                </StackPanel>

                <!-- Center: Overlay actions -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4"
                            HorizontalAlignment="Center">
                    <Button Command="{Binding AddTextOverlayCommand}"
                            IsEnabled="{Binding IsImageLoaded}" Classes="tb">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="T" FontWeight="Bold" FontSize="13"
                                       Foreground="{StaticResource AccentBrush}"/>
                            <TextBlock Text="Add Text" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding AddImageOverlayCommand}"
                            IsEnabled="{Binding IsImageLoaded}" Classes="tb">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="IMG" FontWeight="Bold" FontSize="10"
                                       Foreground="{StaticResource AccentBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Add Image" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding RemoveOverlayCommand}"
                            IsEnabled="{Binding SelectedOverlay, Converter={x:Static ObjectConverters.IsNotNull}}"
                            Classes="danger">
                        <TextBlock Text="Remove Selected" FontSize="12"/>
                    </Button>
                </StackPanel>

                <!-- Right: Export -->
                <Button Grid.Column="2" Command="{Binding GenerateCommand}" Classes="accent">
                    <TextBlock Text="Export All Pages" Foreground="White" FontSize="12"/>
                </Button>
            </Grid>
        </Border>

        <!-- ═══════════════════ MAIN CONTENT (3-column) ═══════════════════ -->
        <Grid Grid.Row="2" ColumnDefinitions="240,*,340">

            <!-- ─── LEFT: Page Navigation Pane ─── -->
            <Border Grid.Column="0"
                    Background="{StaticResource NavPaneBrush}"
                    BorderBrush="{StaticResource SubtleStrokeBrush}"
                    BorderThickness="0,0,1,0">
              <Panel>
                <!-- Empty state: no image loaded yet -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Spacing="12" Margin="24"
                            IsVisible="{Binding !IsImageLoaded}">
                    <TextBlock Text="Get Started"
                               HorizontalAlignment="Center"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="Load a background image to begin creating pages."
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               FontSize="12" TextWrapping="Wrap"
                               Foreground="{StaticResource TextTertiaryBrush}"/>
                    <Button Click="OnLoadImageClick" Classes="accent"
                            HorizontalAlignment="Center"
                            Padding="20,10">
                        <TextBlock Text="Load Image" Foreground="White" FontSize="13"/>
                    </Button>
                </StackPanel>

                <!-- Page nav (visible only when image loaded) -->
                <Grid RowDefinitions="Auto,*,Auto"
                      IsVisible="{Binding IsImageLoaded}">

                    <!-- Pane header -->
                    <StackPanel Grid.Row="0" Margin="12,14,12,6" Spacing="10">
                        <TextBlock Text="Pages"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>

                        <!-- Nav arrows + counter -->
                        <Border Background="{StaticResource LayerFillBrush}"
                                CornerRadius="8" Padding="4"
                                BorderBrush="{StaticResource CardStrokeBrush}"
                                BorderThickness="1">
                            <Grid ColumnDefinitions="32,*,32">
                                <Button Grid.Column="0" Classes="icon"
                                        Command="{Binding PreviousPageCommand}"
                                        IsEnabled="{Binding CanGoPreviousPage}">
                                    <TextBlock Text="&#x276E;" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Button>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding PageNavigationText}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <Button Grid.Column="2" Classes="icon"
                                        Command="{Binding NextPageCommand}"
                                        IsEnabled="{Binding CanGoNextPage}">
                                    <TextBlock Text="&#x276F;" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Button>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Scrollable page list -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Margin="6,4,6,4">
                        <ListBox Name="PageListBox"
                                 Classes="rounded"
                                 ItemsSource="{Binding Pages}"
                                 SelectedIndex="{Binding CurrentPageIndex}"
                                 SelectionChanged="OnPageSelectionChanged"
                                 Background="Transparent"
                                 Padding="2">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:BookPage">
                                    <Border Padding="10,8" Margin="0">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0" Spacing="1">
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock FontSize="11"
                                                           Foreground="{StaticResource TextTertiaryBrush}"
                                                           IsVisible="{Binding PageNumber, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                    <TextBlock.Text>
                                                        <Binding Path="PageNumber" StringFormat="p. {0}"/>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>

                    <!-- Bottom: Page actions + current page props -->
                    <StackPanel Grid.Row="2" Margin="12,4,12,12" Spacing="8">

                        <!-- Add / Remove buttons -->
                        <Grid ColumnDefinitions="*,6,*">
                            <Button Grid.Column="0" Click="OnAddPageClick"
                                    IsEnabled="{Binding IsImageLoaded}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    Classes="accent" Padding="0,8">
                                <TextBlock Text="+ Add Page" Foreground="White" FontSize="12"/>
                            </Button>
                            <Button Grid.Column="2"
                                    Command="{Binding RemovePageCommand}"
                                    IsEnabled="{Binding HasPages}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    Classes="danger" Padding="0,8">
                                <TextBlock Text="Remove" FontSize="12"/>
                            </Button>
                        </Grid>

                        <!-- Current page properties card -->
                        <Border Background="{StaticResource LayerFillBrush}"
                                CornerRadius="8" Padding="12"
                                BorderBrush="{StaticResource CardStrokeBrush}"
                                BorderThickness="1"
                                IsVisible="{Binding HasPages}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Page Details" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           Margin="0,0,0,2"/>
                                <TextBox Text="{Binding CurrentPageTitle}"
                                         Watermark="Page title..."
                                         FontSize="13" CornerRadius="6"
                                         Padding="10,7"/>
                                <TextBox Text="{Binding CurrentPageNumber}"
                                         Watermark="Page # (optional)"
                                         FontSize="12" CornerRadius="6"
                                         Padding="10,7"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
              </Panel>
            </Border>

            <!-- ─── CENTER: Image Canvas ─── -->
            <Border Grid.Column="1" Margin="0"
                    Background="#E5E5E5" ClipToBounds="True">
                <Panel>
                    <!-- Empty state -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Spacing="12"
                                IsVisible="{Binding !IsImageLoaded}">
                        <Border Width="64" Height="64" CornerRadius="16"
                                Background="{StaticResource LayerFillBrush}"
                                HorizontalAlignment="Center">
                            <TextBlock Text="IMG" FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="No background image"
                                   HorizontalAlignment="Center"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextTertiaryBrush}"/>
                        <TextBlock Text="Use 'Load Image' to select a background, then add pages and overlays."
                                   HorizontalAlignment="Center" TextAlignment="Center"
                                   FontSize="13" MaxWidth="320" TextWrapping="Wrap"
                                   Foreground="{StaticResource TextTertiaryBrush}"/>
                    </StackPanel>

                    <Canvas Name="ImageCanvas"
                            PointerPressed="OnCanvasPointerPressed"
                            PointerMoved="OnCanvasPointerMoved"
                            PointerReleased="OnCanvasPointerReleased"
                            Background="Transparent"
                            IsVisible="{Binding IsImageLoaded}">
                        <Image Name="DisplayImage"
                               Source="{Binding ImageSource}"
                               Stretch="Uniform"/>
                        <Border Name="SelectionBox"
                                BorderBrush="{StaticResource AccentLightBrush}"
                                BorderThickness="2"
                                IsVisible="False">
                            <Border.Background>
                                <SolidColorBrush Color="{StaticResource AccentLightColor}" Opacity="0.15"/>
                            </Border.Background>
                        </Border>
                    </Canvas>
                </Panel>
            </Border>

            <!-- ─── RIGHT: Properties Panel ─── -->
            <Border Grid.Column="2"
                    Background="{StaticResource LayerFillAltBrush}"
                    BorderBrush="{StaticResource SubtleStrokeBrush}"
                    BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,14,14,14">
                    <StackPanel Spacing="14">

                        <!-- Section: Overlay List -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="Overlays" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <Border Background="{StaticResource LayerFillBrush}"
                                    CornerRadius="8"
                                    BorderBrush="{StaticResource CardStrokeBrush}"
                                    BorderThickness="1"
                                    Padding="4"
                                    MinHeight="52" MaxHeight="180">
                                <ListBox ItemsSource="{Binding Overlays}"
                                         SelectedItem="{Binding SelectedOverlay}"
                                         Background="Transparent"
                                         Classes="rounded"
                                         Padding="0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="models:OverlayRegion">
                                            <Border Padding="8,6">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <Border Background="{StaticResource AccentSubtleBrush}"
                                                            CornerRadius="4" Padding="6,2"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding TypeIcon}" FontSize="10"
                                                                   FontWeight="Bold"
                                                                   Foreground="{StaticResource AccentBrush}"/>
                                                    </Border>
                                                    <StackPanel Spacing="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Label}" FontWeight="SemiBold"
                                                                   FontSize="12"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                                        <TextBlock Text="{Binding Summary}"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource TextTertiaryBrush}"
                                                                   MaxWidth="180" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </StackPanel>

                        <!-- Section: Position info -->
                        <Border Background="{StaticResource LayerFillBrush}"
                                CornerRadius="8" Padding="12"
                                BorderBrush="{StaticResource CardStrokeBrush}"
                                BorderThickness="1"
                                IsVisible="{Binding SelectedOverlay, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontFamily="Consolas,Menlo,monospace">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="X: {0:F0}  Y: {1:F0}  W: {2:F0}  H: {3:F0}">
                                        <Binding Path="SelectedOverlay.X"/>
                                        <Binding Path="SelectedOverlay.Y"/>
                                        <Binding Path="SelectedOverlay.Width"/>
                                        <Binding Path="SelectedOverlay.Height"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Border>

                        <!-- Section: TEXT OVERLAY PROPERTIES -->
                        <Border Background="{StaticResource LayerFillBrush}"
                                CornerRadius="8" Padding="14"
                                BorderBrush="{StaticResource CardStrokeBrush}"
                                BorderThickness="1"
                                IsVisible="{Binding IsTextOverlaySelected}">
                            <StackPanel Spacing="12" DataContext="{Binding SelectedTextOverlay}"
                                        x:DataType="models:TextOverlayRegion">

                                <TextBlock Text="Text Properties" FontWeight="SemiBold" FontSize="14"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Content" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBox Text="{Binding Text}"
                                             Watermark="Enter text to overlay..."
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             MinHeight="72" MaxHeight="140"
                                             CornerRadius="6" Padding="10,8"
                                             FontSize="13"/>
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Font" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <ComboBox ItemsSource="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).AvailableFonts}"
                                              SelectedItem="{Binding SelectedFont}"
                                              HorizontalAlignment="Stretch"
                                              CornerRadius="6">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="models:EmbeddedFont">
                                                <TextBlock Text="{Binding DisplayName}" FontFamily="{Binding FontFamily}"
                                                           FontSize="13"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>

                                <Grid ColumnDefinitions="*,10,*">
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <TextBlock Text="Size" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <ComboBox ItemsSource="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).FontSizes}"
                                                  SelectedItem="{Binding FontSize}"
                                                  HorizontalAlignment="Stretch"
                                                  CornerRadius="6"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Spacing="4">
                                        <TextBlock Text="Align" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <ComboBox ItemsSource="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).AlignmentOptions}"
                                                  SelectedItem="{Binding Alignment}"
                                                  HorizontalAlignment="Stretch"
                                                  CornerRadius="6"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Color" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <Grid ColumnDefinitions="*,8,36">
                                        <TextBox Grid.Column="0" Text="{Binding FontColor}"
                                                 Watermark="#000000"
                                                 CornerRadius="6" Padding="10,7"
                                                 FontSize="13"
                                                 FontFamily="Consolas,Menlo,monospace"/>
                                        <Border Grid.Column="2" Width="36" Height="36" CornerRadius="6"
                                                BorderBrush="{StaticResource CardStrokeBrush}"
                                                BorderThickness="1">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding FontColor}"/>
                                            </Border.Background>
                                        </Border>
                                    </Grid>
                                    <WrapPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <Button Click="OnColorClick" Tag="#000000" Classes="swatch">
                                            <Border Width="26" Height="26" CornerRadius="6" Background="#1A1A1A"/>
                                        </Button>
                                        <Button Click="OnColorClick" Tag="#FFFFFF" Classes="swatch">
                                            <Border Width="26" Height="26" CornerRadius="6" Background="White"
                                                    BorderBrush="{StaticResource CardStrokeBrush}" BorderThickness="1"/>
                                        </Button>
                                        <Button Click="OnColorClick" Tag="#C42B1C" Classes="swatch">
                                            <Border Width="26" Height="26" CornerRadius="6" Background="#C42B1C"/>
                                        </Button>
                                        <Button Click="OnColorClick" Tag="#005FB8" Classes="swatch">
                                            <Border Width="26" Height="26" CornerRadius="6" Background="#005FB8"/>
                                        </Button>
                                        <Button Click="OnColorClick" Tag="#0F7B0F" Classes="swatch">
                                            <Border Width="26" Height="26" CornerRadius="6" Background="#0F7B0F"/>
                                        </Button>
                                        <Button Click="OnColorClick" Tag="#FFB900" Classes="swatch">
                                            <Border Width="26" Height="26" CornerRadius="6" Background="#FFB900"/>
                                        </Button>
                                        <Button Click="OnColorClick" Tag="#F7630C" Classes="swatch">
                                            <Border Width="26" Height="26" CornerRadius="6" Background="#F7630C"/>
                                        </Button>
                                        <Button Click="OnColorClick" Tag="#881798" Classes="swatch">
                                            <Border Width="26" Height="26" CornerRadius="6" Background="#881798"/>
                                        </Button>
                                    </WrapPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Section: IMAGE OVERLAY PROPERTIES -->
                        <Border Background="{StaticResource LayerFillBrush}"
                                CornerRadius="8" Padding="14"
                                BorderBrush="{StaticResource CardStrokeBrush}"
                                BorderThickness="1"
                                IsVisible="{Binding IsImageOverlaySelected}">
                            <StackPanel Spacing="12" DataContext="{Binding SelectedImageOverlay}"
                                        x:DataType="models:ImageOverlayRegion">

                                <TextBlock Text="Image Properties" FontWeight="SemiBold" FontSize="14"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Source" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <Grid ColumnDefinitions="*,6,Auto">
                                        <TextBox Grid.Column="0" Text="{Binding ImagePath}"
                                                 IsReadOnly="True" Watermark="No image selected"
                                                 CornerRadius="6" Padding="10,7" FontSize="12"/>
                                        <Button Grid.Column="2" Content="Browse"
                                                Click="OnBrowseOverlayImageClick"
                                                Classes="tb"/>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Opacity" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <Grid ColumnDefinitions="*,44">
                                        <Slider Grid.Column="0" Minimum="0" Maximum="100"
                                                Value="{Binding Opacity}" TickFrequency="1"
                                                IsSnapToTickEnabled="True"/>
                                        <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextSecondaryBrush}">
                                            <TextBlock.Text>
                                                <Binding Path="Opacity" StringFormat="{}{0}%"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Placeholder when nothing selected -->
                        <Border Background="{StaticResource LayerFillBrush}"
                                CornerRadius="8" Padding="20"
                                BorderBrush="{StaticResource CardStrokeBrush}"
                                BorderThickness="1">
                            <Border.IsVisible>
                                <Binding Path="SelectedOverlay" Converter="{x:Static ObjectConverters.IsNull}"/>
                            </Border.IsVisible>
                            <TextBlock Text="Select or draw an overlay region to edit its properties."
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       FontSize="13" TextWrapping="Wrap"
                                       TextAlignment="Center"/>
                        </Border>

                        <!-- Section: Output -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="Output" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,4,0,0"/>
                            <Border Background="{StaticResource LayerFillBrush}"
                                    CornerRadius="8" Padding="12"
                                    BorderBrush="{StaticResource CardStrokeBrush}"
                                    BorderThickness="1">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Export Folder" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <Grid ColumnDefinitions="*,6,Auto">
                                        <TextBox Grid.Column="0" Text="{Binding OutputPath}"
                                                 Watermark="Choose output folder..."
                                                 CornerRadius="6" Padding="10,7" FontSize="12"/>
                                        <Button Grid.Column="2" Content="Browse"
                                                Command="{Binding BrowseOutputCommand}"
                                                Classes="tb"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ═══════════════════ STATUS BAR ═══════════════════ -->
        <Border Grid.Row="3"
                Background="{StaticResource LayerFillBrush}"
                BorderBrush="{StaticResource SubtleStrokeBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,5">
            <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
        </Border>

    </Grid>
</Window>
